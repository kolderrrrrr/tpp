<Window x:Class="LocalizedNotepadWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Localized Notepad" Height="620" Width="860"
        MinHeight="480" MinWidth="680"
        Background="#F4F6F8"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0"
                   Background="White"
                   LastChildFill="False">
            <Menu DockPanel.Dock="Left"
                  Background="White">
                <MenuItem x:Name="FileMenuItem" Header="_File">
                    <MenuItem x:Name="NewMenuItem"
                              Header="_New"
                              InputGestureText="Ctrl+N"
                              Click="NewMenuItem_Click" />
                    <MenuItem x:Name="OpenMenuItem"
                              Header="_Open..."
                              InputGestureText="Ctrl+O"
                              Click="OpenMenuItem_Click" />
                    <MenuItem x:Name="SaveMenuItem"
                              Header="_Save..."
                              InputGestureText="Ctrl+S"
                              Click="SaveMenuItem_Click" />
                    <Separator />
                    <MenuItem x:Name="CloseMenuItem"
                              Header="_Close"
                              Click="CloseMenuItem_Click" />
                </MenuItem>
            </Menu>

            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        Margin="0,6,12,6"
                        VerticalAlignment="Center">
                <TextBlock x:Name="LanguageLabelTextBlock"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           Foreground="#1F2937"
                           Text="Language" />
                <ComboBox x:Name="LanguageComboBox"
                          Width="150"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Code"
                          SelectionChanged="LanguageComboBox_SelectionChanged" />
            </StackPanel>
        </DockPanel>

        <TextBox x:Name="EditorTextBox"
                 Grid.Row="1"
                 Margin="16"
                 Padding="12"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="15"
                 Background="White"
                 BorderBrush="#C7D0DB"
                 BorderThickness="1"
                 TextChanged="EditorTextBox_TextChanged" />

        <Border Grid.Row="2"
                Padding="12,7"
                Background="White"
                BorderBrush="#D7DEE8"
                BorderThickness="0,1,0,0">
            <DockPanel LastChildFill="True">
                <TextBlock x:Name="FileNameTextBlock"
                           DockPanel.Dock="Left"
                           Margin="0,0,16,0"
                           FontSize="13"
                           Foreground="#1F2937" />
                <TextBlock x:Name="StatusTextBlock"
                           FontSize="13"
                           Foreground="#4B5563"
                           TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
