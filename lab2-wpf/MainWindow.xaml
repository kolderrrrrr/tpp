<Window x:Class="CalculatorWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор" Height="560" Width="420"
        MinHeight="520" MinWidth="380"
        Background="#F3F6FA"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="CalculatorButton" TargetType="Button">
            <Setter Property="Margin" Value="4" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#CAD3DF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#1A202C" />
        </Style>

        <Style x:Key="OperatorButton" TargetType="Button" BasedOn="{StaticResource CalculatorButton}">
            <Setter Property="Background" Value="#E7F0FF" />
            <Setter Property="Foreground" Value="#1E4E8C" />
        </Style>

        <Style x:Key="EqualsButton" TargetType="Button" BasedOn="{StaticResource CalculatorButton}">
            <Setter Property="Background" Value="#2F80ED" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#2F80ED" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="150" />
        </Grid.RowDefinitions>

        <TextBox x:Name="DisplayTextBox"
                 Grid.Row="0"
                 Height="64"
                 Margin="0,0,0,14"
                 Padding="12"
                 FontSize="28"
                 FontWeight="SemiBold"
                 HorizontalContentAlignment="Right"
                 VerticalContentAlignment="Center"
                 IsReadOnly="True"
                 Text="0"
                 Background="White"
                 BorderBrush="#CAD3DF"
                 BorderThickness="1" />

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Content="C" Grid.Row="0" Grid.Column="0" Tag="Clear" Click="ClearButton_Click" Style="{StaticResource CalculatorButton}" />
            <Button Content="(" Grid.Row="0" Grid.Column="1" Tag="(" Click="InputButton_Click" Style="{StaticResource CalculatorButton}" />
            <Button Content=")" Grid.Row="0" Grid.Column="2" Tag=")" Click="InputButton_Click" Style="{StaticResource CalculatorButton}" />
            <Button Content="/" Grid.Row="0" Grid.Column="3" Tag="/" Click="InputButton_Click" Style="{StaticResource OperatorButton}" />

            <Button Content="7" Grid.Row="1" Grid.Column="0" Tag="7" Click="InputButton_Click" Style="{StaticResource CalculatorButton}" />
            <Button Content="8" Grid.Row="1" Grid.Column="1" Tag="8" Click="InputButton_Click" Style="{StaticResource CalculatorButton}" />
            <Button Content="9" Grid.Row="1" Grid.Column="2" Tag="9" Click="InputButton_Click" Style="{StaticResource CalculatorButton}" />
            <Button Content="*" Grid.Row="1" Grid.Column="3" Tag="*" Click="InputButton_Click" Style="{StaticResource OperatorButton}" />

            <Button Content="4" Grid.Row="2" Grid.Column="0" Tag="4" Click="InputButton_Click" Style="{StaticResource CalculatorButton}" />
            <Button Content="5" Grid.Row="2" Grid.Column="1" Tag="5" Click="InputButton_Click" Style="{StaticResource CalculatorButton}" />
            <Button Content="6" Grid.Row="2" Grid.Column="2" Tag="6" Click="InputButton_Click" Style="{StaticResource CalculatorButton}" />
            <Button Content="-" Grid.Row="2" Grid.Column="3" Tag="-" Click="InputButton_Click" Style="{StaticResource OperatorButton}" />

            <Button Content="1" Grid.Row="3" Grid.Column="0" Tag="1" Click="InputButton_Click" Style="{StaticResource CalculatorButton}" />
            <Button Content="2" Grid.Row="3" Grid.Column="1" Tag="2" Click="InputButton_Click" Style="{StaticResource CalculatorButton}" />
            <Button Content="3" Grid.Row="3" Grid.Column="2" Tag="3" Click="InputButton_Click" Style="{StaticResource CalculatorButton}" />
            <Button Content="+" Grid.Row="3" Grid.Column="3" Tag="+" Click="InputButton_Click" Style="{StaticResource OperatorButton}" />

            <Button Content="0" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Tag="0" Click="InputButton_Click" Style="{StaticResource CalculatorButton}" />
            <Button Content="." Grid.Row="4" Grid.Column="2" Tag="." Click="InputButton_Click" Style="{StaticResource CalculatorButton}" />
            <Button Content="=" Grid.Row="4" Grid.Column="3" Tag="Equals" Click="EqualsButton_Click" Style="{StaticResource EqualsButton}" />
        </Grid>

        <GroupBox Grid.Row="2"
                  Header="История вычислений"
                  Margin="0,14,0,0"
                  FontSize="14"
                  Foreground="#2D3748">
            <ListBox x:Name="HistoryListBox"
                     Margin="8"
                     FontSize="14"
                     Background="White"
                     BorderBrush="#CAD3DF" />
        </GroupBox>
    </Grid>
</Window>
