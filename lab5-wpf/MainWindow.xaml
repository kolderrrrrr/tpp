<Window x:Class="NotepadWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Блокнот - Новый документ" Height="620" Width="860"
        MinHeight="460" MinWidth="620"
        Background="#F4F6F8"
        WindowStartupLocation="CenterScreen">
    <Window.CommandBindings>
        <CommandBinding Command="New"
                        Executed="NewCommand_Executed"
                        CanExecute="Command_CanExecute" />
        <CommandBinding Command="Open"
                        Executed="OpenCommand_Executed"
                        CanExecute="Command_CanExecute" />
        <CommandBinding Command="Save"
                        Executed="SaveCommand_Executed"
                        CanExecute="Command_CanExecute" />
        <CommandBinding Command="SaveAs"
                        Executed="SaveAsCommand_Executed"
                        CanExecute="Command_CanExecute" />
    </Window.CommandBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0"
              Background="White"
              BorderBrush="#D7DEE8"
              BorderThickness="0,0,0,1">
            <MenuItem Header="_Файл">
                <MenuItem Header="_Новый"
                          Command="New"
                          InputGestureText="Ctrl+N" />
                <MenuItem Header="_Открыть..."
                          Command="Open"
                          InputGestureText="Ctrl+O" />
                <Separator />
                <MenuItem Header="_Сохранить"
                          Command="Save"
                          InputGestureText="Ctrl+S" />
                <MenuItem Header="Сохранить _как..."
                          Command="SaveAs" />
            </MenuItem>
        </Menu>

        <TextBox x:Name="EditorTextBox"
                 Grid.Row="1"
                 Margin="16"
                 Padding="12"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="15"
                 Background="White"
                 BorderBrush="#C7D0DB"
                 BorderThickness="1"
                 TextChanged="EditorTextBox_TextChanged" />

        <Border Grid.Row="2"
                Padding="12,7"
                Background="White"
                BorderBrush="#D7DEE8"
                BorderThickness="0,1,0,0">
            <DockPanel LastChildFill="True">
                <TextBlock x:Name="FileNameTextBlock"
                           DockPanel.Dock="Left"
                           Margin="0,0,16,0"
                           FontSize="13"
                           Foreground="#1F2937"
                           Text="Новый документ" />
                <TextBlock x:Name="StatusTextBlock"
                           FontSize="13"
                           Foreground="#4B5563"
                           Text="Готово"
                           TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
