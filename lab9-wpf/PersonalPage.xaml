<Page x:Class="MultiStepFormWPF.PersonalPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Личные данные">
    <Page.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="#C7D0DB" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="38" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="BorderBrush" Value="#C7D0DB" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="MinWidth" Value="118" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2F80ED" />
            <Setter Property="BorderBrush" Value="#2F80ED" />
        </Style>
    </Page.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="#1F2937" Text="Шаг 1 из 3: личные данные" />
            <TextBlock Margin="0,6,0,0" FontSize="14" Foreground="#4B5563" Text="Заполните имя, фамилию и дату рождения." />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,14">
                <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Foreground="#1F2937" Text="Имя" />
                <TextBox x:Name="FirstNameTextBox" />
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,0,0,14">
                <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Foreground="#1F2937" Text="Фамилия" />
                <TextBox x:Name="LastNameTextBox" />
            </StackPanel>

            <StackPanel Grid.Row="2">
                <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Foreground="#1F2937" Text="Дата рождения" />
                <DatePicker x:Name="BirthDatePicker" />
            </StackPanel>
        </Grid>

        <TextBlock x:Name="ErrorTextBlock"
                   Grid.Row="2"
                   Margin="0,14,0,0"
                   FontSize="13"
                   Foreground="#D64545"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="3"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Content="Далее"
                    Click="NextButton_Click"
                    Style="{StaticResource PrimaryButton}" />
        </StackPanel>
    </Grid>
</Page>
