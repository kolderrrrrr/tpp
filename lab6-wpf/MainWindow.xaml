<Window x:Class="AnimatedCalculatorWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Анимированный калькулятор" Height="620" Width="430"
        MinHeight="570" MinWidth="390"
        Background="#F4F6F8"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="CalculatorButton" TargetType="Button">
            <EventSetter Event="Loaded" Handler="CalculatorButton_Loaded" />
            <Setter Property="Height" Value="66" />
            <Setter Property="Margin" Value="5" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1F2937" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#C7D0DB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1.08"
                                             Duration="0:0:0.12" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1.08"
                                             Duration="0:0:0.12" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1"
                                             Duration="0:0:0.12" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1"
                                             Duration="0:0:0.12" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OperationButton" TargetType="Button" BasedOn="{StaticResource CalculatorButton}">
            <Setter Property="Background" Value="#E1F0FF" />
            <Setter Property="BorderBrush" Value="#9CC8F5" />
            <Setter Property="Foreground" Value="#174A7C" />
        </Style>

        <Style x:Key="EqualsButton" TargetType="Button" BasedOn="{StaticResource CalculatorButton}">
            <Setter Property="Background" Value="#2F80ED" />
            <Setter Property="BorderBrush" Value="#2F80ED" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="ClearButton" TargetType="Button" BasedOn="{StaticResource CalculatorButton}">
            <Setter Property="Background" Value="#FFE2E2" />
            <Setter Property="BorderBrush" Value="#F5A3A3" />
            <Setter Property="Foreground" Value="#A33434" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,16"
                Padding="16"
                Background="#1F2937"
                BorderBrush="#111827"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="ExpressionTextBlock"
                           Grid.Row="0"
                           HorizontalAlignment="Right"
                           FontSize="15"
                           Foreground="#B7C0CC"
                           Text="" />
                <TextBlock x:Name="DisplayTextBlock"
                           Grid.Row="1"
                           HorizontalAlignment="Right"
                           Margin="0,8,0,0"
                           FontSize="42"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Text="0"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Row="0" Grid.Column="0" Content="C" Style="{StaticResource ClearButton}" Click="ClearButton_Click" PreviewMouseDown="Button_PreviewMouseDown" PreviewMouseUp="Button_PreviewMouseUp" />
            <Button Grid.Row="0" Grid.Column="1" Content="/" Style="{StaticResource OperationButton}" Click="OperationButton_Click" PreviewMouseDown="Button_PreviewMouseDown" PreviewMouseUp="Button_PreviewMouseUp" />
            <Button Grid.Row="0" Grid.Column="2" Content="*" Style="{StaticResource OperationButton}" Click="OperationButton_Click" PreviewMouseDown="Button_PreviewMouseDown" PreviewMouseUp="Button_PreviewMouseUp" />
            <Button Grid.Row="0" Grid.Column="3" Content="-" Style="{StaticResource OperationButton}" Click="OperationButton_Click" PreviewMouseDown="Button_PreviewMouseDown" PreviewMouseUp="Button_PreviewMouseUp" />

            <Button Grid.Row="1" Grid.Column="0" Content="7" Style="{StaticResource CalculatorButton}" Click="NumberButton_Click" PreviewMouseDown="Button_PreviewMouseDown" PreviewMouseUp="Button_PreviewMouseUp" />
            <Button Grid.Row="1" Grid.Column="1" Content="8" Style="{StaticResource CalculatorButton}" Click="NumberButton_Click" PreviewMouseDown="Button_PreviewMouseDown" PreviewMouseUp="Button_PreviewMouseUp" />
            <Button Grid.Row="1" Grid.Column="2" Content="9" Style="{StaticResource CalculatorButton}" Click="NumberButton_Click" PreviewMouseDown="Button_PreviewMouseDown" PreviewMouseUp="Button_PreviewMouseUp" />
            <Button Grid.Row="1" Grid.Column="3" Content="+" Grid.RowSpan="2" Height="142" Style="{StaticResource OperationButton}" Click="OperationButton_Click" PreviewMouseDown="Button_PreviewMouseDown" PreviewMouseUp="Button_PreviewMouseUp" />

            <Button Grid.Row="2" Grid.Column="0" Content="4" Style="{StaticResource CalculatorButton}" Click="NumberButton_Click" PreviewMouseDown="Button_PreviewMouseDown" PreviewMouseUp="Button_PreviewMouseUp" />
            <Button Grid.Row="2" Grid.Column="1" Content="5" Style="{StaticResource CalculatorButton}" Click="NumberButton_Click" PreviewMouseDown="Button_PreviewMouseDown" PreviewMouseUp="Button_PreviewMouseUp" />
            <Button Grid.Row="2" Grid.Column="2" Content="6" Style="{StaticResource CalculatorButton}" Click="NumberButton_Click" PreviewMouseDown="Button_PreviewMouseDown" PreviewMouseUp="Button_PreviewMouseUp" />

            <Button Grid.Row="3" Grid.Column="0" Content="1" Style="{StaticResource CalculatorButton}" Click="NumberButton_Click" PreviewMouseDown="Button_PreviewMouseDown" PreviewMouseUp="Button_PreviewMouseUp" />
            <Button Grid.Row="3" Grid.Column="1" Content="2" Style="{StaticResource CalculatorButton}" Click="NumberButton_Click" PreviewMouseDown="Button_PreviewMouseDown" PreviewMouseUp="Button_PreviewMouseUp" />
            <Button Grid.Row="3" Grid.Column="2" Content="3" Style="{StaticResource CalculatorButton}" Click="NumberButton_Click" PreviewMouseDown="Button_PreviewMouseDown" PreviewMouseUp="Button_PreviewMouseUp" />
            <Button Grid.Row="3" Grid.Column="3" Content="=" Grid.RowSpan="2" Height="142" Style="{StaticResource EqualsButton}" Click="EqualsButton_Click" PreviewMouseDown="Button_PreviewMouseDown" PreviewMouseUp="Button_PreviewMouseUp" />

            <Button Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Content="0" Style="{StaticResource CalculatorButton}" Click="NumberButton_Click" PreviewMouseDown="Button_PreviewMouseDown" PreviewMouseUp="Button_PreviewMouseUp" />
            <Button Grid.Row="4" Grid.Column="2" Content="." Style="{StaticResource CalculatorButton}" Click="DecimalButton_Click" PreviewMouseDown="Button_PreviewMouseDown" PreviewMouseUp="Button_PreviewMouseUp" />
        </Grid>
    </Grid>
</Window>
